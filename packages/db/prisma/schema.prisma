generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  context       UserContext?
  suggestions   Suggestion[]
  collections   Collection[]
  searchQueries SearchQuery[]
  hostedGroups  Group[]             @relation("HostedGroups")
  groupMembers  GroupMember[]
  createdPlans  GroupPlan[]         @relation("CreatedPlans")
  optionVotes   PlanVote[]
  safetyCircles SafetyCircle[]      @relation("OwnedSafetyCircles")
  safetyMembers SafetyCircleMember[]
  locationShares LocationShare[]    @relation("OwnedLocationShares")
  shareViewers  LocationShareViewer[]
  safetyCheckIns SafetyCheckIn[]

  @@map("users")
}

model UserContext {
  id                   String   @id @default(cuid())
  userId               String   @unique
  energyLevel          String   @default("medium") // high | medium | low
  preferredSanctuaries String[] @default([])
  silenceStart         String   @default("22:00")
  silenceEnd           String   @default("08:00")
  circadianWakeTime    String   @default("07:15")
  calendarProvider     String?  // google | outlook
  calendarToken        String?  // encrypted
  healthProvider       String?  // apple_health | google_fit | oura
  lastSynced           DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_contexts")
}

model Suggestion {
  id           String   @id @default(cuid())
  userId       String
  title        String
  description  String
  category     String   // rest | focus | social | nature | movement | dining
  location     String?
  distanceMins Int?
  moodTags     String[] @default([])
  contextTags  String[] @default([])
  imageUrl     String?
  whyItFits    String?
  aiGenerated  Boolean  @default(true)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, category])
  @@map("suggestions")
}

model Collection {
  id          String         @id @default(cuid())
  userId      String
  name        String
  description String?
  type        CollectionType @default(FOLDER)
  coverImage  String?
  isPrivate   Boolean        @default(false)
  icon        String?        @default("🗂")
  dateStart   DateTime?
  dateEnd     DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CollectionItem[]

  @@index([userId, type])
  @@map("collections")
}

enum CollectionType {
  TRIP
  FOLDER
  SAVED
}

model CollectionItem {
  id             String     @id @default(cuid())
  collectionId   String
  placeName      String
  placeLocation  String?
  placeImageUrl  String?
  notes          String?
  savedAt        DateTime   @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@index([collectionId, savedAt(sort: Desc)])
  @@map("collection_items")
}

model SearchQuery {
  id           String   @id @default(cuid())
  userId       String
  queryText    String?
  moodFilters  String[] @default([])
  resultsCount Int      @default(0)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("search_queries")
}

model Group {
  id          String      @id @default(cuid())
  name        String
  description String?
  hostUserId  String
  status      GroupStatus @default(ACTIVE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  host    User          @relation("HostedGroups", fields: [hostUserId], references: [id], onDelete: Cascade)
  members GroupMember[]
  plans   GroupPlan[]

  @@index([hostUserId, status])
  @@map("groups")
}

enum GroupStatus {
  ACTIVE
  ARCHIVED
}

model GroupMember {
  id                   String          @id @default(cuid())
  groupId               String
  userId                String
  role                  GroupMemberRole @default(MEMBER)
  notificationsEnabled  Boolean         @default(true)
  joinedAt              DateTime        @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId, joinedAt(sort: Desc)])
  @@map("group_members")
}

enum GroupMemberRole {
  HOST
  MEMBER
}

model GroupPlan {
  id              String          @id @default(cuid())
  groupId          String
  createdByUserId  String
  title            String
  notes            String?
  status           GroupPlanStatus @default(DRAFT)
  windowStart      DateTime?
  windowEnd        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  group          Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy      User            @relation("CreatedPlans", fields: [createdByUserId], references: [id], onDelete: Cascade)
  options        GroupPlanOption[]
  itineraryItems GroupItineraryItem[]

  @@index([groupId, status, updatedAt(sort: Desc)])
  @@map("group_plans")
}

enum GroupPlanStatus {
  DRAFT
  VOTING
  FINALIZED
  ARCHIVED
}

model GroupPlanOption {
  id               String   @id @default(cuid())
  planId           String
  title            String
  description      String?
  category         String
  score            Int      @default(0)
  whyItFits        String?
  createdByUserId  String?
  createdAt        DateTime @default(now())

  plan  GroupPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  votes PlanVote[]

  @@index([planId, createdAt(sort: Asc)])
  @@map("group_plan_options")
}

model PlanVote {
  id        String   @id @default(cuid())
  optionId   String
  userId     String
  vote       Int      @default(1)
  createdAt  DateTime @default(now())

  option GroupPlanOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([optionId, userId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("plan_votes")
}

model GroupItineraryItem {
  id         String   @id @default(cuid())
  planId      String
  sequence    Int
  startsAt    DateTime
  endsAt      DateTime?
  title       String
  type        String
  notes       String?
  createdAt   DateTime @default(now())

  plan GroupPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, sequence])
  @@index([planId, startsAt(sort: Asc)])
  @@map("group_itinerary_items")
}

model SafetyCircle {
  id                       String   @id @default(cuid())
  ownerUserId              String
  name                     String
  liveShareEnabled         Boolean  @default(true)
  quietCheckInIntervalMins Int      @default(90)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  owner    User                @relation("OwnedSafetyCircles", fields: [ownerUserId], references: [id], onDelete: Cascade)
  members  SafetyCircleMember[]
  shares   LocationShare[]
  checkIns SafetyCheckIn[]

  @@index([ownerUserId, createdAt(sort: Desc)])
  @@map("safety_circles")
}

model SafetyCircleMember {
  id        String            @id @default(cuid())
  circleId   String
  userId     String
  role       SafetyCircleRole @default(MEMBER)
  joinedAt   DateTime         @default(now())

  circle SafetyCircle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([circleId, userId])
  @@index([userId, joinedAt(sort: Desc)])
  @@map("safety_circle_members")
}

enum SafetyCircleRole {
  OWNER
  MEMBER
}

model LocationShare {
  id               String              @id @default(cuid())
  circleId         String
  ownerUserId      String
  status           LocationShareStatus @default(ACTIVE)
  destinationLabel String?
  startedAt        DateTime            @default(now())
  expiresAt        DateTime
  endedAt          DateTime?
  createdAt        DateTime            @default(now())

  circle  SafetyCircle          @relation(fields: [circleId], references: [id], onDelete: Cascade)
  owner   User                  @relation("OwnedLocationShares", fields: [ownerUserId], references: [id], onDelete: Cascade)
  viewers LocationShareViewer[]

  @@index([circleId, status, startedAt(sort: Desc)])
  @@map("location_shares")
}

enum LocationShareStatus {
  ACTIVE
  PAUSED
  ENDED
}

model LocationShareViewer {
  id        String   @id @default(cuid())
  shareId    String
  userId     String
  createdAt  DateTime @default(now())

  share LocationShare @relation(fields: [shareId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([shareId, userId])
  @@map("location_share_viewers")
}

model SafetyCheckIn {
  id         String              @id @default(cuid())
  circleId    String
  userId      String
  status      SafetyCheckInStatus
  note        String?
  createdAt   DateTime            @default(now())

  circle SafetyCircle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([circleId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("safety_check_ins")
}

enum SafetyCheckInStatus {
  SAFE
  DELAYED
  HELP
}
