generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  context       UserContext?
  suggestions   Suggestion[]
  collections   Collection[]
  searchQueries SearchQuery[]

  @@map("users")
}

model UserContext {
  id                   String   @id @default(cuid())
  userId               String   @unique
  energyLevel          String   @default("medium") // high | medium | low
  preferredSanctuaries String[] @default([])
  silenceStart         String   @default("22:00")
  silenceEnd           String   @default("08:00")
  circadianWakeTime    String   @default("07:15")
  calendarProvider     String?  // google | outlook
  calendarToken        String?  // encrypted
  healthProvider       String?  // apple_health | google_fit | oura
  lastSynced           DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_contexts")
}

model Suggestion {
  id           String   @id @default(cuid())
  userId       String
  title        String
  description  String
  category     String   // rest | focus | social | nature | movement | dining
  location     String?
  distanceMins Int?
  moodTags     String[] @default([])
  contextTags  String[] @default([])
  imageUrl     String?
  whyItFits    String?
  aiGenerated  Boolean  @default(true)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, category])
  @@map("suggestions")
}

model Collection {
  id          String         @id @default(cuid())
  userId      String
  name        String
  description String?
  type        CollectionType @default(FOLDER)
  coverImage  String?
  isPrivate   Boolean        @default(false)
  icon        String?        @default("🗂")
  dateStart   DateTime?
  dateEnd     DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CollectionItem[]

  @@index([userId, type])
  @@map("collections")
}

enum CollectionType {
  TRIP
  FOLDER
  SAVED
}

model CollectionItem {
  id             String     @id @default(cuid())
  collectionId   String
  placeName      String
  placeLocation  String?
  placeImageUrl  String?
  notes          String?
  savedAt        DateTime   @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@index([collectionId, savedAt(sort: Desc)])
  @@map("collection_items")
}

model SearchQuery {
  id           String   @id @default(cuid())
  userId       String
  queryText    String?
  moodFilters  String[] @default([])
  resultsCount Int      @default(0)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("search_queries")
}
